# Copy to .env (same directory) and fill in. Never commit the real .env.
#   cp .env.example .env && nano .env

# Released image tag to run. Bump this to deploy a newer release, then re-pull + up.
APP_VERSION=2026.2.6

# First-admin bootstrap. Used only when the users table is EMPTY (fresh DB or after
# resetting the users table) — the backend then creates this admin with
# must-change-password=true. On an already-populated DB these are ignored, but they
# must still be set (compose requires them). Use a strong password.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-now

# Browser origin(s) allowed to call the API (CORS). MUST be the public URL you serve the
# app from — including scheme, no trailing slash. Comma-separated for multiple. If this is
# wrong, browser logins fail with "Invalid CORS request".
APP_CORS_ALLOWED_ORIGINS=https://team-management.example.com

# Optional — Google Custom Search for customer logo lookup. Leave blank to disable.
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
